# Copy to .env.local. All NEXT_PUBLIC_* are exposed to the browser (this is a client dApp).
# The web app builds and runs with the defaults below; only the registry address must be
# set after a one-time deploy to enable the on-chain "publish receipt" button.

# Network the dApp targets. 1AM supports "preview" and "preprod"; the local stack uses
# "undeployed". Must match the network your wallet is set to.
NEXT_PUBLIC_MIDNIGHT_NETWORK=preview

# Wallet connector key under window.midnight[...]. 1AM injects under "1am".
NEXT_PUBLIC_WALLET_KEY=1am

# Address of the deployed Night Check Registry. Leave blank until you deploy it
# (see deploy-kit/ for the CLI deploy, or the in-app one-time deploy).
NEXT_PUBLIC_REGISTRY_ADDRESS=

# Base URL where the compiled zk keys are served (defaults to the app's own /zk).
NEXT_PUBLIC_ZK_BASE_URL=/zk

# Tag the operator's auditor identity is derived from for in-app publishing (optional).
NEXT_PUBLIC_AUDITOR_TAG=night-check-operator
